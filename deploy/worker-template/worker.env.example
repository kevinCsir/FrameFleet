# Generated worker runtimes get a concrete worker.env based on this shape.
# Values here are examples only.

WORKER_LISTEN_ADDR=:19001
WORKER_ADVERTISED_ADDRESS=127.0.0.1:19001
ENTRY_BASE_URL=http://127.0.0.1:18080
WORKER_TOTAL_SLOTS=2

WORKER_DATA_DIR=/tmp/framefleet-workers/worker-19001/data
WORKER_INPUT_DIR=/tmp/framefleet-workers/worker-19001/input
WORKER_ENGINE_BINARY=/path/to/FrameFleet/worker-node/cpp/build/framefleet-engine

WORKER_LOG_LEVEL=info
WORKER_LOG_OUTPUT=file
WORKER_LOG_FILE=/tmp/framefleet-workers/worker-19001/logs/worker-agent.log

WORKER_HEARTBEAT_INTERVAL_SECONDS=10
WORKER_SOURCE_SCAN_INTERVAL_SECONDS=10
WORKER_DISK_TOTAL_BYTES=1000000000
WORKER_DISK_FREE_BYTES=800000000
